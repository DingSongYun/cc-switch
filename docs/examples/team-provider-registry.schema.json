{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cc-switch.local/schemas/team-provider-registry.schema.json",
  "title": "Team Provider Registry",
  "type": "object",
  "required": ["version", "teamId", "updatedAt", "providers"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "teamId": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/providerEntry" }
    }
  },
  "$defs": {
    "providerEntry": {
      "type": "object",
      "required": ["id", "name", "apps", "baseUrl", "apiKeyPolicy"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-_]{0,63}$"
        },
        "name": { "type": "string", "minLength": 1 },
        "apps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["claude", "claude-desktop", "codex", "gemini"]
          },
          "uniqueItems": true
        },
        "baseUrl": { "type": "string", "format": "uri" },
        "apiKeyPolicy": { "type": "string", "const": "local_required" },
        "models": {
          "type": "object",
          "properties": {
            "claudeDesktop": { "$ref": "#/$defs/claudeDesktopConfig" }
          },
          "additionalProperties": true
        },
        "websiteUrl": { "type": "string" },
        "notes": { "type": "string" },
        "icon": { "type": "string" },
        "iconColor": { "type": "string" },
        "meta": { "type": "object" }
      },
      "additionalProperties": false
    },
    "claudeDesktopConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["direct", "proxy"]
        },
        "modelRoutes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["model"],
            "properties": {
              "model": { "type": "string", "minLength": 1 },
              "labelOverride": { "type": "string" },
              "supports1m": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
